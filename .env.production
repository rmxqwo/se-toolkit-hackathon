# PostgreSQL Database
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD_123
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_TO_SECURE_PASSWORD_123@postgres:5432/resume_builder

# Qwen API (DashScope) - Get from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_actual_api_key_here
QWEN_MODEL=qwen-plus

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# PDF Settings
PDF_DEFAULT_FONT=Helvetica
PDF_PAGE_SIZE=A4

# Docker Compose Settings
DB_PORT=5432
APP_PORT=8000
